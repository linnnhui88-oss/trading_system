# ============================================
# 量化交易系统环境变量配置模板
# 复制此文件为 .env 并填入实际值
# 注意：
# 1. 这是模板文件，不会被 Web 页面自动同步更新
# 2. Web 设置页中的“模型提供商管理”配置写入数据库，不写入 .env
# 3. 请优先以当前稳定运行的 .env 为准，不要直接用本模板覆盖线上配置
# ============================================

# --------------------------------------------
# 交易所 API 配置（币安）
# --------------------------------------------
BINANCE_API_KEY=your_binance_api_key_here
BINANCE_SECRET_KEY=your_binance_secret_key_here

# 代理配置（如需）
PROXY_URL=http://127.0.0.1:7897

# --------------------------------------------
# Telegram 通知配置
# --------------------------------------------
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHAT_ID=your_telegram_chat_id_here

# --------------------------------------------
# AI 模型提供商配置说明
# --------------------------------------------
# 当前系统的 AI 提供商配置（API Key / Base URL / Model Name / 启用状态）
# 由 Web 设置页中的“模型提供商管理”写入数据库，不再要求写入 .env
# 如需修改，请在 Web 页面中操作。
#
# 兼容说明：
# 现有策略实现仍会直接读取 GEMINI_API_KEY（历史兼容），
# 因此在保持当前稳定运行模式下建议保留该变量。
GEMINI_API_KEY=your_gemini_api_key_here

# --------------------------------------------
# 交易参数配置
# --------------------------------------------
# 最大仓位金额（USDT）
MAX_POSITION_USDT=50

# 最大日亏损（USDT）
MAX_DAILY_LOSS_USDT=30

# 默认杠杆倍数
DEFAULT_LEVERAGE=3

# 止损比例（%）
STOP_LOSS_PERCENT=2

# 止盈比例（%）
TAKE_PROFIT_PERCENT=4

# 跟踪止损比例（%）
TRAILING_STOP_PERCENT=1.0

# 最大持仓数量
MAX_POSITIONS_COUNT=2

# 每日最大错误次数
MAX_ERRORS_PER_DAY=10

# --------------------------------------------
# 策略配置
# --------------------------------------------
DEFAULT_STRATEGY=MA99_MTF
USE_CONSENSUS_STRATEGY=false
STRATEGIES_ENABLED=MACD,RSI,BollingerBands,MA99_MTF

# --------------------------------------------
# 邮件通知配置（可选）
# --------------------------------------------
EMAIL_ENABLED=false
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your_email@gmail.com
EMAIL_PASSWORD=your_email_password_or_app_password
EMAIL_TO=recipient@example.com

# --------------------------------------------
# Web 服务配置
# --------------------------------------------
WEB_HOST=0.0.0.0
WEB_PORT=5000
SECRET_KEY=your-secret-key-change-this

# --------------------------------------------
# 日志与调试配置
# --------------------------------------------
LOG_LEVEL=INFO
DEBUG=false
