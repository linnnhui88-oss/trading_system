# 交易所API配置
# 请填写你的Binance API密钥
BINANCE_API_KEY=your_binance_api_key_here
BINANCE_SECRET_KEY=your_binance_secret_key_here
PROXY_URL=http://127.0.0.1:7897

# Telegram通知配置（可选）
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHAT_ID=your_chat_id_here

# Gemini AI配置（可选）
GEMINI_API_KEY=your_gemini_api_key_here

# 邮件通知配置（可选）
EMAIL_ENABLED=false
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your_email@gmail.com
EMAIL_PASSWORD=your_app_password
EMAIL_TO=recipient@email.com

# 交易参数
MAX_POSITION_USDT=50
MAX_DAILY_LOSS_USDT=30
DEFAULT_LEVERAGE=3
STOP_LOSS_PERCENT=20
TAKE_PROFIT_PERCENT=80
TRAILING_STOP_PERCENT=5
MAX_POSITIONS_COUNT=1
MAX_ERRORS_PER_DAY=10

# 策略配置
DEFAULT_STRATEGY=MA99_MTF
USE_CONSENSUS_STRATEGY=false
STRATEGIES_ENABLED=MACD,RSI,BollingerBands,MA99_MTF

# 系统配置
WEB_HOST=0.0.0.0
WEB_PORT=5000
LOG_LEVEL=INFO
SECRET_KEY=your-secret-key-change-this

# 调试模式
DEBUG=false
